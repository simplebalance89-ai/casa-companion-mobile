# Casa Companion ESP32-S3 generated sdkconfig
# Fill in Wi-Fi credentials below, then build with idf.py.

CONFIG_IDF_TARGET="esp32s3"

# CPU / PSRAM
CONFIG_ESP32S3_DEFAULT_CPU_FREQ_240=y
CONFIG_ESP32S3_SPIRAM_SUPPORT=y
CONFIG_SPIRAM_MODE_OCT=y
CONFIG_SPIRAM_SPEED_80M=y

# FreeRTOS
CONFIG_FREERTOS_HZ=1000

# Bluetooth
CONFIG_BT_ENABLED=y
CONFIG_BT_BLUEDROID_ENABLED=y
CONFIG_BT_BLE_42_FEATURES_SUPPORTED=y

# Network
CONFIG_LWIP_MAX_SOCKETS=16

# Logging
CONFIG_LOG_DEFAULT_LEVEL_INFO=y

# Power management
CONFIG_PM_ENABLE=y

# Compiler
CONFIG_COMPILER_OPTIMIZATION_DEFAULT=y

# Casa Companion project config
CONFIG_CASA_WIFI_SSID="the wilsons eero"
CONFIG_CASA_WIFI_PASSWORD="Dreamhouse21"
CONFIG_CASA_DEVICE_ID="d97548f1-44c2-4cfe-9f35-f73c0938a376"
CONFIG_CASA_API_KEY="wZunjbVdcbOWLjBulHNAA2xfJDcxVLhUusIOOpRYsxM"
CONFIG_CASA_VOICE_SERVER_URL="wss://casa-voice-agent.fly.dev"
CONFIG_CASA_WAKE_WORD_PRIMARY="orsetto"
CONFIG_CASA_WAKE_WORD_SECONDARY="drago"
# CONFIG_CASA_USE_LIBOPUS is not set

# Default GPIO / hardware settings
CONFIG_CASA_WAKE_GPIO=0
CONFIG_CASA_WAKE_HOLD_MS=5000
CONFIG_CASA_I2S_MIC_BCK=4
CONFIG_CASA_I2S_MIC_WS=5
CONFIG_CASA_I2S_MIC_DATA=6
CONFIG_CASA_I2S_SPK_BCK=7
CONFIG_CASA_I2S_SPK_WS=15
CONFIG_CASA_I2S_SPK_DATA=16
CONFIG_CASA_PN532_I2C_PORT=0
CONFIG_CASA_PN532_SDA=8
CONFIG_CASA_PN532_SCL=9
CONFIG_CASA_BATTERY_ADC_CHANNEL=3
CONFIG_CASA_BATTERY_ADC_VREF_MV=1100
CONFIG_CASA_BATTERY_DIVIDER_R1=100
CONFIG_CASA_BATTERY_DIVIDER_R2=100
CONFIG_CASA_BATTERY_SLEEP_THRESHOLD=10
CONFIG_CASA_BATTERY_REPORT_MS=30000
CONFIG_CASA_SLEEP_DURATION_MS=60000
